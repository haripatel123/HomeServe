<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container-xl">
    <div class="error-page">
        <div class="error-code">500</div>
        <h1 class="error-title"><%= title || 'Something Went Wrong' %></h1>
        <p class="error-msg"><%= message || 'An unexpected error occurred. Please try again later.' %></p>
        <div class="d-flex gap-3 flex-wrap justify-content-center">
            <a href="/" class="btn-green">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Go Home
            </a>
            <button id="go-back-btn" class="btn-outline-custom">← Go Back</button>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('go-back-btn')?.addEventListener('click', function() {
        history.back();
    });
});
</script>

<%- include('partials/footer') %>
