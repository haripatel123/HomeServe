<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="page-wrapper" style="padding-top: 110px;">
<div class="container-xl">

    <!-- Breadcrumb -->
    <div class="breadcrumb-custom">
        <a href="/">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="9 18 15 12 9 6"/></svg>
        <a href="/services/<%= service.service_id %>"><%= service.service_name %></a>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Book Service</span>
    </div>

    <div class="row g-4 mt-1">
        <!-- LEFT: Form -->
        <div class="col-lg-8">
            <div class="dark-card">
                <h1 style="font-size:1.4rem;margin-bottom:0.25rem;">Book Service</h1>
                <p style="color:var(--text-muted);font-size:0.88rem;margin-bottom:1.75rem;">Fill in the details below to complete your booking.</p>

                <!-- Error Alert -->
                <% if (error) { %>
                <div class="alert-dark-error mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <span><%= error %></span>
                </div>
                <% } %>

                <form method="POST" action="/book" class="form-dark" id="bookingForm" novalidate>
                    <!-- Hidden service_id -->
                    <input type="hidden" name="service_id" value="<%= service.service_id %>">

                    <div class="row g-3">
                        <!-- Customer (auto-filled from session) -->
                        <div class="col-md-6">
                            <label class="form-label">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;margin-right:4px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                Booking As
                            </label>
                            <div class="form-control" style="background:rgba(var(--color-ink-rgb,0,0,0),0.03);cursor:default;display:flex;align-items:center;gap:6px;height:38px;">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;opacity:0.5;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                <%= user.name %>
                            </div>
                        </div>

                        <!-- Select Address -->
                        <div class="col-md-6">
                            <label class="form-label" for="address_id">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;margin-right:4px;"><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"/><circle cx="12" cy="10" r="3"/></svg>
                                Select Address
                            </label>
                            <% if (addresses && addresses.length > 0) { %>
                                <select name="address_id" id="address_id" class="form-select" required>
                                    <% addresses.forEach(a => { %>
                                        <option value="<%= a.address_id %>"
                                            <%= (formData.address_id == a.address_id || (a.is_default && !formData.address_id)) ? 'selected' : '' %>>
                                            <%= a.address_type.toUpperCase() %>: <%= a.line1 %>, <%= a.city %>
                                        </option>
                                    <% }); %>
                                </select>
                            <% } else { %>
                                <div class="form-control" style="background:rgba(var(--color-ink-rgb,0,0,0),0.03);cursor:default;color:var(--accent-red);font-weight:600;display:flex;align-items:center;gap:6px;height:38px;font-size:0.8rem;">
                                    No address found. <a href="/profile" style="color:var(--color-action-blue);text-decoration:underline;">Add address</a>
                                </div>
                            <% } %>
                        </div>

                        <!-- Provider -->
                        <div class="col-md-6">
                            <label class="form-label" for="provider_id">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;margin-right:4px;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                Select Provider
                            </label>
                            <select name="provider_id" id="provider_id" class="form-select" required>
                                <option value="">— Choose provider —</option>
                                <% service.providers.forEach(p => { %>
                                <option value="<%= p.provider_id %>"
                                    <%= (formData.provider_id == p.provider_id) ? 'selected' : '' %>>
                                    <%= p.name %> ★ <%= parseFloat(p.avg_rating).toFixed(1) %>
                                </option>
                                <% }); %>
                            </select>
                        </div>

                        <!-- Variant -->
                        <% if (service.variants && service.variants.length > 0) { %>
                        <div class="col-md-6">
                            <label class="form-label" for="variant_id">Service Package</label>
                            <select name="variant_id" id="variant_id" class="form-select">
                                <option value="">— Base price —</option>
                                <% service.variants.forEach(v => { %>
                                <option value="<%= v.variant_id %>"
                                    data-price="<%= v.price %>"
                                    <%= (formData.variant_id == v.variant_id) ? 'selected' : '' %>>
                                    <%= v.variant_name %> — ₹<%= parseFloat(v.price).toLocaleString('en-IN') %>
                                </option>
                                <% }); %>
                            </select>
                        </div>
                        <% } %>

                        <!-- Date -->
                        <div class="col-md-6">
                            <label class="form-label" for="booking_date">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;margin-right:4px;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                Booking Date
                            </label>
                            <input type="date" name="booking_date" id="booking_date"
                                   class="form-control"
                                   min="<%= new Date().toISOString().split('T')[0] %>"
                                   value="<%= formData.booking_date || '' %>"
                                   required>
                        </div>

                        <!-- Time -->
                        <div class="col-md-6">
                            <label class="form-label" for="booking_time">Booking Time</label>
                            <input type="time" name="booking_time" id="booking_time"
                                   class="form-control"
                                   value="<%= formData.booking_time || '10:00' %>"
                                   required>
                        </div>

                        <!-- Payment Method -->
                        <div class="col-md-6">
                            <label class="form-label" for="payment_method">Payment Method</label>
                            <select name="payment_method" id="payment_method" class="form-select">
                                <option value="Cash"   <%=formData.payment_method==='Cash'  ?'selected':''%>>Cash</option>
                                <option value="UPI"    <%=formData.payment_method==='UPI'   ?'selected':''%>>UPI</option>
                                <option value="Card"   <%=formData.payment_method==='Card'  ?'selected':''%>>Card</option>
                                <option value="Wallet" <%=formData.payment_method==='Wallet'?'selected':''%>>Wallet</option>
                            </select>
                        </div>

                        <!-- Coupon -->
                        <div class="col-12">
                            <label class="form-label" for="coupon_code">Coupon Code (Optional)</label>
                            <div class="input-group">
                                <input type="text" name="coupon_code" id="coupon_code"
                                       class="form-control"
                                       placeholder="e.g. WELCOME10"
                                       maxlength="30"
                                       value="<%= formData.coupon_code || '' %>"
                                       style="text-transform:uppercase;">
                                <button type="button" class="btn-outline-custom" id="applyCouponBtn" style="border-radius:0 var(--radius-md) var(--radius-md) 0;border-left:none;">
                                    Apply
                                </button>
                            </div>
                            <div id="coupon-result"></div>
                        </div>

                        <!-- Notes -->
                        <div class="col-12">
                            <label class="form-label" for="notes">Special Notes (Optional)</label>
                            <textarea name="notes" id="notes" class="form-control" rows="2"
                                      maxlength="500"
                                      placeholder="Any special instructions for the provider..."><%= formData.notes || '' %></textarea>
                            <div style="font-size:0.75rem;color:var(--text-muted);margin-top:0.25rem;">Max 500 characters</div>
                        </div>

                        <!-- Submit -->
                        <div class="col-12 pt-1">
                            <button type="submit" class="btn-green" id="submitBtn" style="min-width:180px;">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                Confirm Booking
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- RIGHT: Summary Panel -->
        <div class="col-lg-4">
            <div class="dark-card" style="position:sticky;top:90px;">
                <h3 style="font-size:0.9rem;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:1.25rem;color:var(--text-muted);">Order Summary</h3>

                <div style="margin-bottom:1.25rem;">
                    <div style="font-weight:600;font-size:0.95rem;margin-bottom:0.25rem;"><%= service.service_name %></div>
                    <div style="font-size:0.8rem;color:var(--text-muted);"><%= service.category_name %></div>
                </div>

                <div style="border-top:1px solid var(--border-color);padding-top:1rem;">
                    <div class="d-flex justify-content-between mb-2" style="font-size:0.88rem;">
                        <span style="color:var(--text-muted);">Base Price</span>
                        <span>₹<%= parseFloat(service.base_price).toLocaleString('en-IN') %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2" id="variant-row" style="font-size:0.88rem;display:none!important;">
                        <span style="color:var(--text-muted);">Package</span>
                        <span id="variant-price-display">—</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2" id="discount-row" style="font-size:0.88rem;display:none!important;">
                        <span style="color:var(--accent-green);">Discount</span>
                        <span id="discount-display" style="color:var(--accent-green);">—</span>
                    </div>
                    <div style="border-top:1px solid var(--border-color);padding-top:0.75rem;margin-top:0.5rem;">
                        <div class="d-flex justify-content-between">
                            <span style="font-weight:700;">Total</span>
                            <span class="mono" style="font-size:1.3rem;font-weight:700;color:var(--accent-green);" id="total-display">
                                ₹<%= parseFloat(service.base_price).toLocaleString('en-IN') %>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="mt-3" style="background:rgba(0,0,0,0.02);border:1px solid var(--border-color);border-radius:var(--radius-sm);padding:0.75rem;">
                    <div style="font-size:0.78rem;color:var(--text-muted);">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--accent-green)" stroke-width="2" style="width:13px;height:13px;margin-right:4px;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        Secure booking · All prices inclusive
                    </div>
                </div>

                <div class="mt-3" style="font-size:0.78rem;color:var(--text-muted);">
                    <strong>Demo coupons:</strong> WELCOME10, CLEAN20, SAVE15, MEGA25, FIRST50
                </div>
            </div>
        </div>
    </div>
</div>
</div>

<%- include('partials/footer') %>

<script>
const serviceId  = '<%= service.service_id %>';
const basePrice  = parseFloat('<%= service.base_price %>');

// Prevent double-submit
const bookingForm  = document.getElementById('bookingForm');
const submitBtn    = document.getElementById('submitBtn');
let submitted = false;

bookingForm?.addEventListener('submit', function(e) {
    if (submitted) { e.preventDefault(); return; }

    // Client-side validation
    const customerId = document.getElementById('customer_id').value;
    const providerId = document.getElementById('provider_id').value;
    const date       = document.getElementById('booking_date').value;
    const time       = document.getElementById('booking_time').value;

    if (!customerId) { alert('Please select a customer.'); e.preventDefault(); return; }
    if (!providerId) { alert('Please select a provider.'); e.preventDefault(); return; }
    if (!date) { alert('Please select a booking date.'); e.preventDefault(); return; }
    if (!time) { alert('Please select a booking time.'); e.preventDefault(); return; }

    // Past date check
    const today = new Date(); today.setHours(0,0,0,0);
    if (new Date(date) < today) { alert('Booking date cannot be in the past.'); e.preventDefault(); return; }

    submitted = true;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-green"></span> Processing...';
});

// Live price calculation
async function updatePrice() {
    const variantSel = document.getElementById('variant_id');
    const couponEl   = document.getElementById('coupon_code');
    const variantId  = variantSel ? variantSel.value : '';
    const coupon     = couponEl ? couponEl.value.trim() : '';

    try {
        const params = new URLSearchParams({ service_id: serviceId });
        if (variantId) params.set('variant_id', variantId);
        if (coupon)    params.set('coupon_code', coupon);

        const res  = await fetch(`/api/calculate-amount?${params}`);
        const data = await res.json();

        if (data.error) {
            document.getElementById('total-display').textContent = '—';
        } else {
            const amount = parseFloat(data.amount);
            document.getElementById('total-display').textContent =
                '₹' + amount.toLocaleString('en-IN', {minimumFractionDigits:2});

            const variantRow = document.getElementById('variant-row');
            if (variantId && variantRow) variantRow.style.display = 'flex';
            else if (variantRow)         variantRow.style.display = 'none';
        }
    } catch (err) {
        console.error('Price calculation error:', err);
    }
}

document.getElementById('variant_id')?.addEventListener('change', updatePrice);

// Coupon apply
document.getElementById('applyCouponBtn')?.addEventListener('click', async function() {
    const couponCode = document.getElementById('coupon_code').value.trim();
    const resultEl   = document.getElementById('coupon-result');

    if (!couponCode) {
        resultEl.textContent = 'Please enter a coupon code.';
        resultEl.style.color = 'var(--accent-red)';
        return;
    }

    document.getElementById('coupon_code').value = couponCode.toUpperCase();
    resultEl.textContent = 'Validating...';
    resultEl.style.color = 'var(--text-muted)';

    try {
        const variantId = document.getElementById('variant_id')?.value || '';
        const params = new URLSearchParams({
            service_id:  serviceId,
            coupon_code: couponCode.toUpperCase(),
        });
        if (variantId) params.set('variant_id', variantId);

        const res  = await fetch(`/api/calculate-amount?${params}`);
        const data = await res.json();

        if (data.error) {
            resultEl.textContent = '✗ ' + data.error;
            resultEl.style.color = 'var(--accent-red)';
        } else {
            const amount = parseFloat(data.amount);
            resultEl.textContent = '✓ Coupon applied! Final: ₹' + amount.toLocaleString('en-IN', {minimumFractionDigits:2});
            resultEl.style.color = 'var(--accent-green)';
            document.getElementById('total-display').textContent =
                '₹' + amount.toLocaleString('en-IN', {minimumFractionDigits:2});
        }
    } catch (err) {
        resultEl.textContent = '✗ Failed to validate coupon.';
        resultEl.style.color = 'var(--accent-red)';
    }
});
</script>
