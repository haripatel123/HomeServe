<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="page-wrapper">
<div class="container-xl">

    <!-- Page Header -->
    <div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h1>My Bookings</h1>
            <p style="color:var(--text-muted);font-size:0.88rem;margin-top:0.25rem;margin-bottom:0;">
                <%= total %> total booking<%= total !== 1 ? 's' : '' %>
            </p>
        </div>
        <!-- Customer Selector -->
        <div class="d-flex align-items-center gap-2">
            <label style="font-size:0.82rem;color:var(--text-muted);white-space:nowrap;">View as:</label>
            <form method="GET" action="/bookings" style="margin:0;">
                <% 
                let currentCustomerName = 'Select Customer';
                const activeCust = customers.find(c => c.customer_id == currentCustomer);
                if (activeCust) {
                    currentCustomerName = activeCust.name;
                }
                %>
                <div class="custom-dropdown-container">
                    <div class="custom-dropdown-trigger">
                        <span><%= currentCustomerName %></span>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="chevron-icon"><polyline points="6 9 12 15 18 9"/></svg>
                    </div>
                    <div class="custom-dropdown-menu">
                        <% customers.forEach(c => { %>
                        <div class="custom-dropdown-item <%= currentCustomer == c.customer_id ? 'active' : '' %>" data-value="<%= c.customer_id %>">
                            <%= c.name %>
                        </div>
                        <% }); %>
                    </div>
                    <select id="customer-select" name="customer_id" style="display: none;">
                        <% customers.forEach(c => { %>
                        <option value="<%= c.customer_id %>" <%= currentCustomer == c.customer_id ? 'selected' : '' %>>
                            <%= c.name %>
                        </option>
                        <% }); %>
                    </select>
                </div>
            </form>
        </div>
    </div>

    <!-- Success Alert -->
    <% if (success) { %>
    <div class="alert-dark-success mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span>Booking confirmed! <% if (newBookingId) { %>Your booking ID is <strong>#<%= newBookingId %></strong>.<% } %></span>
    </div>
    <% } %>

    <% if (reviewSuccess) { %>
    <div class="alert-dark-success mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;flex-shrink:0;"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg>
        <span>Review submitted successfully! Thank you for your feedback.</span>
    </div>
    <% } %>

    <!-- Bookings Table -->
    <% if (bookings.length === 0) { %>
    <div class="dark-card">
        <div class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <h3>No Bookings Yet</h3>
            <p>You haven't made any bookings. Browse services to get started.</p>
            <a href="/" class="btn-green mt-3">Browse Services</a>
        </div>
    </div>
    <% } else { %>
    <% 
    // Helper function to compute initials from provider name
    function getInitials(name) {
        const parts = (name || '').trim().split(/\s+/);
        if (parts.length === 0 || !parts[0]) return 'P';
        if (parts.length === 1) return parts[0].substring(0, 2).toUpperCase();
        return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
    }

    // Helper function to assign dynamic provider colors
    function getProviderAvatarStyle(providerId) {
        const palettes = {
            1: 'background: rgba(0, 130, 124, 0.15); color: #00ffb7; border-color: rgba(0, 255, 183, 0.3);',
            2: 'background: rgba(186, 85, 211, 0.15); color: #e0aaff; border-color: rgba(224, 170, 255, 0.3);',
            3: 'background: rgba(255, 165, 0, 0.12); color: #ffb703; border-color: rgba(255, 183, 3, 0.3);',
            4: 'background: rgba(70, 130, 180, 0.15); color: #8ecae6; border-color: rgba(142, 202, 230, 0.3);',
        };
        return palettes[providerId] || 'background: rgba(255, 255, 255, 0.08); color: var(--text-primary); border-color: var(--border-color);';
    }

    // Helper function to format relative date strings
    function getRelativeDateStr(dateVal, timeVal) {
        const dateObj = new Date(dateVal);
        const today = new Date();
        today.setHours(0,0,0,0);
        
        const bookingDate = new Date(dateVal);
        bookingDate.setHours(0,0,0,0);
        
        const diffTime = today.getTime() - bookingDate.getTime();
        const diffDays = Math.round(diffTime / (1000 * 60 * 60 * 24));
        const formattedTime = timeVal ? timeVal.substring(0, 5) : '';
        
        if (diffDays === 0) {
            return `Today, ${formattedTime}`;
        } else if (diffDays === 1) {
            return `Yesterday, ${formattedTime}`;
        } else if (diffDays === -1) {
            return `Tomorrow, ${formattedTime}`;
        } else if (diffDays > 1 && diffDays < 7) {
            return `${diffDays} days ago`;
        } else if (diffDays >= 7 && diffDays < 30) {
            const weeks = Math.floor(diffDays / 7);
            return `${weeks} week${weeks > 1 ? 's' : ''} ago`;
        } else {
            return dateObj.toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'});
        }
    }
    %>
    <div class="dark-card" style="padding:0;overflow:hidden;">
        <div class="table-responsive">
            <table class="dark-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Services</th>
                        <th>Provider</th>
                        <th>Date & Time</th>
                        <th>Amount</th>
                        <th>Payment</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% bookings.forEach((b, idx) => {
                        // Row density padding - Top 3 recent entries get more breathing room
                        const cellPadding = idx < 3 ? 'padding: 1.15rem 1rem;' : 'padding: 0.65rem 1rem;';
                        
                        // Cancelled row styling: 55% opacity
                        const isCancelled = b.status === 'Cancelled';
                        const rowStyle = isCancelled ? 'opacity: 0.55;' : '';
                        
                        // Service name strikethrough for cancelled rows
                        const serviceStyle = isCancelled ? 'text-decoration: line-through;' : '';

                        // Amount color: flag pending, active, or large (>= 1000) transactions in teal; make completed/cancelled plain grey/white
                        const isHighValueOrActive = b.status === 'Pending' || b.status === 'Confirmed' || parseFloat(b.total_amount) >= 1000;
                        const amountColor = (isHighValueOrActive && !isCancelled) ? 'color: var(--accent-green); font-weight: 700;' : 'color: var(--text-secondary); font-weight: 500;';

                        // Glow indicator configuration for Booking Status
                        const statusDotConfig = {
                            'Pending':    { dotColor: '#ffd000', borderColor: 'rgba(255, 208, 0, 0.25)', textColor: '#ffd000' },
                            'Confirmed':  { dotColor: '#00ffb7', borderColor: 'rgba(0, 255, 183, 0.25)', textColor: '#00ffb7' },
                            'InProgress': { dotColor: '#3a86ff', borderColor: 'rgba(58, 134, 255, 0.25)', textColor: '#8ecae6' },
                            'Completed':  { dotColor: '#ffffff', borderColor: 'rgba(255, 255, 255, 0.2)', textColor: '#ffffff' },
                            'Cancelled':  { dotColor: '#ff6b6b', borderColor: 'rgba(255, 107, 107, 0.2)', textColor: '#ff6b6b' }
                        }[b.status] || { dotColor: '#ffffff', borderColor: 'rgba(255, 255, 255, 0.1)', textColor: 'var(--text-secondary)' };

                        // Minimalist text configuration for Payment Status
                        const payConfig = {
                            'Paid':     { icon: '✓', color: '#00ffb7', label: 'Paid' },
                            'Pending':  { icon: '◷', color: '#ffd000', label: 'Unpaid' },
                            'Refunded': { icon: '↺', color: '#4dd4cf', label: 'Refunded' },
                            'Failed':   { icon: '⚠', color: '#ff6b6b', label: 'Failed' }
                        }[b.payment_status || 'Pending'] || { icon: '◷', color: 'var(--text-muted)', label: b.payment_status || 'Pending' };
                    %>
                    <tr style="<%= rowStyle %>">
                        <td style="<%= cellPadding %>">
                            <span class="mono" style="color:var(--text-muted);font-size:0.82rem;">#<%= b.booking_id %></span>
                        </td>
                        <td style="<%= cellPadding %>">
                            <div style="font-weight:600;font-size:0.88rem;color:var(--text-primary);<%= serviceStyle %>">
                                <%= b.services || 'N/A' %>
                            </div>
                            <div style="font-size:0.75rem;color:var(--text-muted);">
                                at <%= b.city %>
                            </div>
                        </td>
                        <td style="<%= cellPadding %>">
                            <!-- Initials-based Avatar + Provider Name -->
                            <div style="display:flex;align-items:center;gap:0.65rem;">
                                <div style="width:26px;height:26px;border-radius:50%;<%= getProviderAvatarStyle(b.provider_id) %>display:flex;align-items:center;justify-content:center;font-size:0.68rem;font-weight:700;flex-shrink:0;letter-spacing:0;border:1px solid;">
                                    <%= getInitials(b.provider_name) %>
                                </div>
                                <div style="font-size:0.88rem;color:var(--text-secondary);"><%= b.provider_name %></div>
                            </div>
                        </td>
                        <td style="<%= cellPadding %>">
                            <div style="font-size:0.88rem;font-weight:500;">
                                <%= getRelativeDateStr(b.booking_date, b.booking_time) %>
                            </div>
                        </td>
                        <td style="<%= cellPadding %>">
                            <span class="mono" style="<%= amountColor %>">
                                ₹<%= parseFloat(b.total_amount).toLocaleString('en-IN') %>
                            </span>
                        </td>
                        <td style="<%= cellPadding %>">
                            <!-- Soft, text-based payment tag with reduced visual weight -->
                            <span style="font-size:0.8rem;color:<%= payConfig.color %>;font-weight:500;display:inline-flex;align-items:center;gap:0.3rem;">
                                <span style="font-family:monospace;font-size:0.9rem;font-weight:bold;"><%= payConfig.icon %></span>
                                <%= payConfig.label %>
                            </span>
                        </td>
                        <td style="<%= cellPadding %>">
                            <!-- Handcrafted glowing dot status tag -->
                            <div style="display:inline-flex;align-items:center;gap:0.45rem;padding:0.25rem 0.6rem;background:rgba(255,255,255,0.02);border:1px solid <%= statusDotConfig.borderColor %>;border-left:3px solid <%= statusDotConfig.dotColor %>;border-radius:4px;font-size:0.72rem;font-weight:600;color:<%= statusDotConfig.textColor %>;letter-spacing:0.3px;text-transform:uppercase;">
                                <span style="display:inline-block;width:5px;height:5px;border-radius:50%;background:<%= statusDotConfig.dotColor %>;box-shadow: 0 0 6px <%= statusDotConfig.dotColor %>;"></span>
                                <%= b.status %>
                            </div>
                        </td>
                        <td style="<%= cellPadding %>">
                            <% if (b.status === 'Completed' && !b.has_review) { %>
                            <% const safeName = (b.provider_name || ''); %>
                            <a href="javascript:void(0)" class="write-review-btn"
                                    style="font-size:0.8rem;color:var(--color-current-teal);font-weight:600;display:inline-flex;align-items:center;gap:0.25rem;text-decoration:none;"
                                    data-booking-id="<%= b.booking_id %>"
                                    data-provider-id="<%= b.provider_id %>"
                                    data-provider-name="<%= safeName %>">
                                Leave a review →
                            </a>
                            <% } else if (b.status === 'Completed' && b.has_review) { %>
                            <span style="font-size:0.8rem;color:var(--text-muted);display:inline-flex;align-items:center;gap:0.25rem;">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--accent-green)" stroke-width="2.5" style="width:12px;height:12px;"><polyline points="20 6 9 17 4 12"/></svg>
                                Reviewed
                            </span>
                            <% } else if (b.status === 'Pending' || b.status === 'Confirmed') { %>
                            <form method="POST" action="/bookings/<%= b.booking_id %>/status" style="margin:0;" class="cancel-booking-form">
                                <input type="hidden" name="new_status" value="Cancelled">
                                <input type="hidden" name="redirect_to" value="/bookings?customer_id=<%= currentCustomer %>">
                                <button type="submit" class="btn-danger-custom" style="font-size: 0.75rem; padding: 0.25rem 0.65rem;">Cancel</button>
                            </form>
                            <% } else { %>
                            <span style="font-size:0.78rem;color:var(--text-muted);">—</span>
                            <% } %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="d-flex justify-content-center align-items-center gap-2 mt-4">
        <% if (page > 1) { %>
        <a href="/bookings?customer_id=<%= currentCustomer %>&page=<%= page-1 %>" class="btn-outline-custom">← Prev</a>
        <% } %>
        <span style="color:var(--text-muted);font-size:0.88rem;">Page <%= page %> of <%= totalPages %></span>
        <% if (page < totalPages) { %>
        <a href="/bookings?customer_id=<%= currentCustomer %>&page=<%= page+1 %>" class="btn-outline-custom">Next →</a>
        <% } %>
    </div>
    <% } %>
    <% } %>
</div>
</div>

<!-- Review Modal -->
<div id="reviewModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:2000;align-items:center;justify-content:center;">
    <div class="dark-card" style="max-width:480px;width:90%;position:relative;margin:1rem;">
        <button id="close-review-modal-btn" style="position:absolute;top:1rem;right:1rem;background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:1.2rem;">✕</button>
        <h3 style="font-size:1.1rem;margin-bottom:0.25rem;">Leave a Review</h3>
        <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1.5rem;" id="reviewProviderName"></p>

        <form method="POST" id="reviewForm" class="form-dark">
            <input type="hidden" name="customer_id" value="<%= currentCustomer %>">
            <input type="hidden" name="provider_id" id="reviewProviderId">

            <div class="mb-3">
                <label class="form-label">Rating</label>
                <div class="d-flex flex-row-reverse justify-content-end gap-1" style="font-size:1.8rem;">
                    <input type="radio" name="rating" value="5" id="r5" class="star-input" required>
                    <label for="r5" class="star-label">★</label>
                    <input type="radio" name="rating" value="4" id="r4" class="star-input">
                    <label for="r4" class="star-label">★</label>
                    <input type="radio" name="rating" value="3" id="r3" class="star-input">
                    <label for="r3" class="star-label">★</label>
                    <input type="radio" name="rating" value="2" id="r2" class="star-input">
                    <label for="r2" class="star-label">★</label>
                    <input type="radio" name="rating" value="1" id="r1" class="star-input">
                    <label for="r1" class="star-label">★</label>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="reviewComment">Comment (Optional)</label>
                <textarea name="comment" id="reviewComment" class="form-control" rows="3"
                          maxlength="500" placeholder="Share your experience..."></textarea>
            </div>

            <button type="submit" class="btn-green">Submit Review</button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>

<script>
function openReviewModal(bookingId, providerId, providerName) {
    document.getElementById('reviewForm').action = `/bookings/${bookingId}/review`;
    document.getElementById('reviewProviderId').value = providerId;
    document.getElementById('reviewProviderName').textContent = 'Provider: ' + providerName;
    document.getElementById('reviewModal').style.display = 'flex';
}
function closeReviewModal() {
    document.getElementById('reviewModal').style.display = 'none';
}
document.getElementById('reviewModal')?.addEventListener('click', function(e) {
    if (e.target === this) closeReviewModal();
});

// CSP compliant event listeners
document.addEventListener('DOMContentLoaded', function() {
    // Customer view selector
    document.getElementById('customer-select')?.addEventListener('change', function() {
        this.form.submit();
    });

    // Write review buttons
    document.querySelectorAll('.write-review-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const bookingId = this.getAttribute('data-booking-id');
            const providerId = this.getAttribute('data-provider-id');
            const providerName = this.getAttribute('data-provider-name');
            openReviewModal(bookingId, providerId, providerName);
        });
    });

    // Cancel booking forms
    document.querySelectorAll('.cancel-booking-form').forEach(form => {
        form.addEventListener('submit', function(e) {
            if (!confirm('Cancel this booking?')) {
                e.preventDefault();
            }
        });
    });

    // Close review modal button
    document.getElementById('close-review-modal-btn')?.addEventListener('click', closeReviewModal);
});
</script>
