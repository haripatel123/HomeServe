<nav class="navbar-floating-capsule">
    <!-- Brand/Logo -->
    <a href="/" class="navbar-brand-pill">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:18px;height:18px;color:var(--color-ink);margin-right:2px;vertical-align:-3px;">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Home<span>Serve</span>
    </a>
    
    <!-- Divider -->
    <div class="nav-divider d-none d-md-block"></div>
    
    <!-- Desktop Links Capsule -->
    <div class="nav-links-pill d-none d-md-flex">
        <div class="nav-active-capsule"></div>
        <a href="/" class="nav-item-pill <%= currentUrl === '/' ? 'active' : '' %>">Services</a>
        <a href="/bookings?customer_id=<%= typeof currentCustomer !== 'undefined' ? currentCustomer : 1 %>" class="nav-item-pill <%= currentUrl === '/bookings' ? 'active' : '' %>">Bookings</a>
        <a href="/provider?provider_id=<%= typeof currentProvider !== 'undefined' ? currentProvider : 1 %>" class="nav-item-pill <%= currentUrl === '/provider' ? 'active' : '' %>">Providers</a>
        <a href="/analytics" class="nav-item-pill <%= currentUrl === '/analytics' ? 'active' : '' %>">Analytics</a>
    </div>

    <!-- Mobile Menu Toggle Button inside Navbar Capsule -->
    <button class="d-md-none" id="mobileMenuToggle" aria-label="Menu" style="border:none;background:none;padding:2px 8px;margin-left:4px;color:var(--color-ink);">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>
</nav>

<!-- Mobile Floating Dropdown Capsule Menu -->
<div class="mobile-menu-floating d-md-none" id="mobileMenu" style="display:none;">
    <a href="/" class="nav-item-pill <%= currentUrl === '/' ? 'active' : '' %>">Services</a>
    <a href="/bookings?customer_id=<%= typeof currentCustomer !== 'undefined' ? currentCustomer : 1 %>" class="nav-item-pill <%= currentUrl === '/bookings' ? 'active' : '' %>">Bookings</a>
    <a href="/provider?provider_id=<%= typeof currentProvider !== 'undefined' ? currentProvider : 1 %>" class="nav-item-pill <%= currentUrl === '/provider' ? 'active' : '' %>">Providers</a>
    <a href="/analytics" class="nav-item-pill <%= currentUrl === '/analytics' ? 'active' : '' %>">Analytics</a>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // 1. Entrance animation on load
    const nav = document.querySelector('.navbar-floating-capsule');
    if (nav) {
        requestAnimationFrame(() => {
            nav.classList.add('loaded');
        });
    }

    // 2. Mobile Menu Toggle logic
    const toggleBtn = document.getElementById('mobileMenuToggle');
    const mobileMenu = document.getElementById('mobileMenu');
    if (toggleBtn && mobileMenu) {
        toggleBtn.addEventListener('click', function() {
            mobileMenu.classList.toggle('open');
        });
    }

    // 3. Active Sliding Capsule Glide (Vanilla)
    const activeBg = document.querySelector('.nav-active-capsule');
    const linksContainer = document.querySelector('.nav-links-pill');
    const navItems = document.querySelectorAll('.nav-links-pill .nav-item-pill');
    
    function positionCapsule(target, show = true) {
        if (!target || !activeBg) return;
        
        const left = target.offsetLeft;
        const width = target.offsetWidth;
        const top = target.offsetTop;
        const height = target.offsetHeight;
        
        activeBg.style.left = `${left}px`;
        activeBg.style.width = `${width}px`;
        activeBg.style.top = `${top}px`;
        activeBg.style.height = `${height}px`;
        
        if (show) {
            activeBg.style.opacity = '1';
        } else {
            activeBg.style.opacity = '0';
        }
    }
    
    // Set initial position on active page link
    const activeLink = document.querySelector('.nav-links-pill .nav-item-pill.active');
    if (activeLink && activeBg) {
        activeBg.classList.add('no-transition');
        positionCapsule(activeLink, true);
        
        // Force reflow
        activeBg.offsetHeight;
        activeBg.classList.remove('no-transition');
    }
    
    // Bind mouseover glide events
    navItems.forEach(item => {
        item.addEventListener('mouseenter', function() {
            positionCapsule(this, true);
        });
    });
    
    // Return glide back to active item on container mouseleave
    if (linksContainer) {
        linksContainer.addEventListener('mouseleave', function() {
            const currentActive = document.querySelector('.nav-links-pill .nav-item-pill.active');
            if (currentActive) {
                positionCapsule(currentActive, true);
            } else {
                activeBg.style.opacity = '0';
            }
        });
    }

    // 4. Scroll layout styling overrides & smart hide/show
    let lastScrollY = window.scrollY;
    const filterBar = document.querySelector('.filter-bar');

    window.addEventListener('scroll', function() {
        if (!nav) return;
        const currentScrollY = window.scrollY;
        
        if (currentScrollY > 40) {
            nav.classList.add('scrolled');
        } else {
            nav.classList.remove('scrolled');
        }
        
        // Smart Hide/Show based on scroll direction
        if (currentScrollY > lastScrollY && currentScrollY > 100) {
            nav.classList.add('scroll-down');
            nav.classList.remove('scroll-up');
            if (filterBar) {
                filterBar.classList.add('scroll-down');
            }
        } else if (currentScrollY < lastScrollY) {
            nav.classList.add('scroll-up');
            nav.classList.remove('scroll-down');
            if (filterBar) {
                filterBar.classList.remove('scroll-down');
            }
        }
        
        lastScrollY = currentScrollY;
    });
});
</script>
