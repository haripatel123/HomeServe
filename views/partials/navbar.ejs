<nav class="navbar-dark-custom">
    <div class="container-xl">
        <div class="d-flex align-items-center justify-content-between w-100">
            <!-- Brand -->
            <a href="/" class="navbar-brand-text">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:22px;height:22px;color:#00827c;margin-right:6px;vertical-align:-4px;">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                Home<span>Serve</span>
            </a>

            <!-- Desktop Nav -->
            <div class="d-none d-md-flex align-items-center">
                <div class="nav-menu-capsule">
                    <div class="nav-sliding-highlight"></div>
                    <a href="/" class="nav-link-capsule <%= currentUrl === '/' ? 'active' : '' %>">Services</a>
                    <a href="/bookings?customer_id=<%= typeof currentCustomer !== 'undefined' ? currentCustomer : 1 %>" class="nav-link-capsule <%= currentUrl === '/bookings' ? 'active' : '' %>">My Bookings</a>
                    <a href="/provider?provider_id=<%= typeof currentProvider !== 'undefined' ? currentProvider : 1 %>" class="nav-link-capsule <%= currentUrl === '/provider' ? 'active' : '' %>">Provider</a>
                    <a href="/analytics" class="nav-cta-capsule">Analytics</a>
                </div>
            </div>

            <!-- Mobile Toggle -->
            <button class="d-md-none btn-outline-custom" id="mobileMenuToggle" aria-label="Menu">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px;">
                    <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
        </div>

        <!-- Mobile Menu -->
        <div class="d-md-none" id="mobileMenu" style="display:none;padding-top:1rem;margin-top:0.75rem;">
            <a href="/"          class="nav-link-custom d-block mb-1">Services</a>
            <a href="/bookings"  class="nav-link-custom d-block mb-1">My Bookings</a>
            <a href="/provider"  class="nav-link-custom d-block mb-1">Provider</a>
            <a href="/analytics" class="nav-link-custom d-block">Analytics</a>
        </div>
    </div>
</nav>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const capsule = document.querySelector('.nav-menu-capsule');
    if (!capsule) return;
    
    const highlight = capsule.querySelector('.nav-sliding-highlight');
    const links = capsule.querySelectorAll('.nav-link-capsule, .nav-cta-capsule');
    
    function moveHighlight(target) {
        if (!target) return;
        highlight.style.left = target.offsetLeft + 'px';
        highlight.style.top = target.offsetTop + 'px';
        highlight.style.width = target.offsetWidth + 'px';
        highlight.style.height = target.offsetHeight + 'px';
        highlight.style.opacity = '1';
    }
    
    // Position highlight initially over active link
    const activeLink = capsule.querySelector('.nav-link-capsule.active');
    if (activeLink) {
        moveHighlight(activeLink);
    }
    
    links.forEach(link => {
        link.addEventListener('mouseenter', function() {
            moveHighlight(this);
        });
    });
    
    capsule.addEventListener('mouseleave', function() {
        const currentActive = capsule.querySelector('.nav-link-capsule.active');
        if (currentActive) {
            moveHighlight(currentActive);
        } else {
            highlight.style.opacity = '0';
        }
    });
});
</script>
