<style>
.nav-user-dropdown-container:hover .nav-user-dropdown-menu {
    display: flex !important;
    animation: dropdownFadeIn 0.2s ease-out;
}
.nav-user-dropdown-menu::before {
    content: '';
    position: absolute;
    top: -15px;
    left: 0;
    right: 0;
    height: 15px;
    background: transparent;
}
.dropdown-item-pill:hover {
    background: var(--bg-secondary) !important;
    color: var(--text-primary) !important;
}
</style>

<nav class="navbar-floating-capsule">
    <!-- Brand/Logo -->
    <a href="/" class="navbar-brand-pill">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:18px;height:18px;color:var(--color-ink);margin-right:2px;vertical-align:-3px;">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Home<span>Serve</span>
    </a>
    
    <!-- Divider -->
    <div class="nav-divider d-none d-md-block"></div>
    
    <!-- Desktop Links Capsule -->
    <div class="nav-links-pill d-none d-md-flex">
        <div class="nav-active-capsule"></div>
        <a href="/" class="nav-item-pill <%= currentUrl === '/' ? 'active' : '' %>">Services</a>
        
        <% if (locals.user) { %>
            <% if (user.role === 'customer') { %>
                <a href="/bookings" class="nav-item-pill <%= currentUrl === '/bookings' ? 'active' : '' %>">My Bookings</a>
            <% } else if (user.role === 'provider') { %>
                <a href="/provider" class="nav-item-pill <%= currentUrl === '/provider' ? 'active' : '' %>">Dashboard</a>
            <% } else if (user.role === 'admin') { %>
                <a href="/bookings?customer_id=1" class="nav-item-pill <%= currentUrl === '/bookings' ? 'active' : '' %>">Bookings</a>
                <a href="/provider?provider_id=1" class="nav-item-pill <%= currentUrl === '/provider' ? 'active' : '' %>">Providers</a>
                <a href="/analytics" class="nav-item-pill <%= currentUrl === '/analytics' ? 'active' : '' %>">Analytics</a>
            <% } %>
        <% } %>

        <% if (!locals.user) { %>
            <a href="/login" class="nav-item-pill <%= currentUrl === '/login' ? 'active' : '' %>">Login</a>
            <a href="/register" class="nav-item-pill <%= currentUrl === '/register' ? 'active' : '' %>">Register</a>
        <% } %>
    </div>

    <% if (locals.user) { %>
        <div class="nav-user-dropdown-container d-none d-md-block" style="position:relative;margin-left:8px;">
            <div class="nav-user-badge" style="display:flex;align-items:center;gap:6px;padding:4px 12px;border-radius:20px;background:rgba(var(--color-ink-rgb,0,0,0),0.06);font-size:0.78rem;font-weight:500;color:var(--color-ink);cursor:pointer;transition:all 0.25s ease;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;opacity:0.6;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <%= user.name %>
                <span style="font-size:0.65rem;padding:1px 6px;border-radius:8px;background:var(--color-ink);color:#fff;text-transform:uppercase;letter-spacing:0.5px;"><%= user.role %></span>
            </div>
            
            <!-- Hover Dropdown Menu -->
            <div class="nav-user-dropdown-menu" style="position:absolute;top:100%;right:0;width:200px;background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:8px;box-shadow:var(--shadow-card);display:none;flex-direction:column;gap:4px;margin-top:8px;z-index:9999;">
                <div style="padding:6px 8px;font-size:0.78rem;color:var(--color-metal);border-bottom:1px solid var(--border-color);margin-bottom:4px;word-break:break-all;">
                    <div style="font-weight:600;color:var(--text-primary);"><%= user.name %></div>
                    <div style="font-size:0.72rem;color:var(--text-secondary);"><%= user.email %></div>
                </div>
                <a href="/profile" class="dropdown-item-pill" style="display:flex;align-items:center;gap:6px;padding:6px 10px;font-size:0.8rem;color:var(--color-metal);border-radius:6px;transition:all 0.2s ease;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                    Profile Settings
                </a>
                <a href="/logout" class="dropdown-item-pill" style="display:flex;align-items:center;gap:6px;padding:6px 10px;font-size:0.8rem;color:var(--accent-red);border-radius:6px;transition:all 0.2s ease;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    Logout
                </a>
            </div>
        </div>
    <% } %>

    <!-- Mobile Menu Toggle Button inside Navbar Capsule -->
    <button class="d-md-none" id="mobileMenuToggle" aria-label="Menu" style="border:none;background:none;padding:2px 8px;margin-left:4px;color:var(--color-ink);">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>
</nav>

<!-- Mobile Floating Dropdown Capsule Menu -->
<div class="mobile-menu-floating d-md-none" id="mobileMenu" style="display:none;">
    <a href="/" class="nav-item-pill <%= currentUrl === '/' ? 'active' : '' %>">Services</a>
    
    <% if (locals.user) { %>
        <% if (user.role === 'customer') { %>
            <a href="/bookings" class="nav-item-pill <%= currentUrl === '/bookings' ? 'active' : '' %>">My Bookings</a>
        <% } else if (user.role === 'provider') { %>
            <a href="/provider" class="nav-item-pill <%= currentUrl === '/provider' ? 'active' : '' %>">Dashboard</a>
        <% } else if (user.role === 'admin') { %>
            <a href="/bookings?customer_id=1" class="nav-item-pill <%= currentUrl === '/bookings' ? 'active' : '' %>">Bookings</a>
            <a href="/provider?provider_id=1" class="nav-item-pill <%= currentUrl === '/provider' ? 'active' : '' %>">Providers</a>
            <a href="/analytics" class="nav-item-pill <%= currentUrl === '/analytics' ? 'active' : '' %>">Analytics</a>
        <% } %>
    <% } %>

    <hr style="margin: 6px 0; opacity: 0.15; border-color: var(--color-ink);">
    
    <% if (locals.user) { %>
        <div style="padding:6px 12px;font-size:0.8rem;color:var(--text-muted);display:flex;align-items:center;gap:6px;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;opacity:0.6;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <%= user.name %>
            <span style="font-size:0.65rem;padding:1px 5px;border-radius:6px;background:var(--color-ink);color:#fff;text-transform:uppercase;letter-spacing:0.5px;"><%= user.role %></span>
        </div>
        <a href="/profile" class="nav-item-pill <%= currentUrl === '/profile' ? 'active' : '' %>">Profile Settings</a>
        <a href="/logout" class="nav-item-pill">Logout</a>
    <% } else { %>
        <a href="/login" class="nav-item-pill <%= currentUrl === '/login' ? 'active' : '' %>">Login</a>
        <a href="/register" class="nav-item-pill <%= currentUrl === '/register' ? 'active' : '' %>">Register</a>
    <% } %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // 1. Entrance animation on load
    const nav = document.querySelector('.navbar-floating-capsule');
    if (nav) {
        requestAnimationFrame(() => {
            nav.classList.add('loaded');
        });
    }

    // 2. Mobile Menu Toggle logic
    const toggleBtn = document.getElementById('mobileMenuToggle');
    const mobileMenu = document.getElementById('mobileMenu');
    if (toggleBtn && mobileMenu) {
        toggleBtn.addEventListener('click', function() {
            mobileMenu.classList.toggle('open');
        });
    }

    // 3. Active Sliding Capsule Glide (Vanilla)
    const activeBg = document.querySelector('.nav-active-capsule');
    const linksContainer = document.querySelector('.nav-links-pill');
    const navItems = document.querySelectorAll('.nav-links-pill .nav-item-pill');
    
    function positionCapsule(target, show = true) {
        if (!target || !activeBg) return;
        
        const left = target.offsetLeft;
        const width = target.offsetWidth;
        const top = target.offsetTop;
        const height = target.offsetHeight;
        
        activeBg.style.left = `${left}px`;
        activeBg.style.width = `${width}px`;
        activeBg.style.top = `${top}px`;
        activeBg.style.height = `${height}px`;
        
        if (show) {
            activeBg.style.opacity = '1';
        } else {
            activeBg.style.opacity = '0';
        }
    }
    
    // Set initial position on active page link
    const activeLink = document.querySelector('.nav-links-pill .nav-item-pill.active');
    if (activeLink && activeBg) {
        activeBg.classList.add('no-transition');
        positionCapsule(activeLink, true);
        
        // Force reflow
        activeBg.offsetHeight;
        activeBg.classList.remove('no-transition');
    }
    
    // Bind mouseover glide events
    navItems.forEach(item => {
        item.addEventListener('mouseenter', function() {
            positionCapsule(this, true);
        });
    });
    
    // Return glide back to active item on container mouseleave
    if (linksContainer) {
        linksContainer.addEventListener('mouseleave', function() {
            const currentActive = document.querySelector('.nav-links-pill .nav-item-pill.active');
            if (currentActive) {
                positionCapsule(currentActive, true);
            } else {
                activeBg.style.opacity = '0';
            }
        });
    }

    // 4. Scroll layout styling overrides & smart hide/show
    let lastScrollY = window.scrollY;
    const filterBar = document.querySelector('.filter-bar');

    window.addEventListener('scroll', function() {
        if (!nav) return;
        const currentScrollY = window.scrollY;
        
        if (currentScrollY > 40) {
            nav.classList.add('scrolled');
        } else {
            nav.classList.remove('scrolled');
        }
        
        // Smart Hide/Show based on scroll direction
        if (currentScrollY > lastScrollY && currentScrollY > 100) {
            nav.classList.add('scroll-down');
            nav.classList.remove('scroll-up');
            if (filterBar) {
                filterBar.classList.add('scroll-down');
            }
        } else if (currentScrollY < lastScrollY) {
            nav.classList.add('scroll-up');
            nav.classList.remove('scroll-down');
            if (filterBar) {
                filterBar.classList.remove('scroll-down');
            }
        }
        
        lastScrollY = currentScrollY;
    });
});
</script>

