<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="page-wrapper" style="padding-top: 110px;">
    <div class="container-xl">
        
        <!-- Alerts -->
        <% if (locals.success_msg && success_msg.length > 0) { %>
            <div class="alert-dark-success mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span><%= success_msg %></span>
            </div>
        <% } %>

        <% if (locals.errors && errors.length > 0) { %>
            <div class="alert-dark-error mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <ul class="mb-0 ps-3" style="list-style-type: none; padding-left: 0 !important;">
                    <% errors.forEach(function(error) { %>
                        <li><%= error.msg %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>

        <div class="row g-4">
            <!-- Left: Profile Info -->
            <div class="<%= user.role === 'customer' ? 'col-lg-5' : 'col-lg-6 mx-auto' %>">
                <div class="dark-card">
                    <h2 style="font-size:1.3rem;font-weight:600;margin-bottom:0.25rem;">Account Settings</h2>
                    <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1.5rem;">Update your basic profile details.</p>

                    <form action="/profile/update" method="POST" class="form-dark">
                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="text" class="form-control" value="<%= user.email %>" readonly style="background:rgba(var(--color-ink-rgb,0,0,0),0.03);cursor:not-allowed;">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Role</label>
                            <input type="text" class="form-control text-uppercase" value="<%= user.role %>" readonly style="background:rgba(var(--color-ink-rgb,0,0,0),0.03);cursor:not-allowed;font-size:0.75rem;font-weight:600;">
                        </div>
                        <div class="mb-3">
                            <label for="name" class="form-label">Full Name</label>
                            <input type="text" class="form-control" id="name" name="name" value="<%= locals.formData.name || user.name %>" required minlength="2">
                        </div>
                        <div class="mb-3">
                            <label for="phone" class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" id="phone" name="phone" value="<%= locals.formData.phone || user.phone %>" required pattern="\d{10}">
                        </div>

                        <% if (user.role === 'provider' && providerDetails) { %>
                            <div class="mb-3">
                                <label for="bio" class="form-label">Bio / Description</label>
                                <textarea class="form-control" id="bio" name="bio" rows="4" style="resize:vertical;"><%= locals.formData.bio || providerDetails.bio || '' %></textarea>
                            </div>
                            <div class="mb-3">
                                <label for="experience_yrs" class="form-label">Years of Experience</label>
                                <input type="number" class="form-control" id="experience_yrs" name="experience_yrs" value="<%= locals.formData.experience_yrs || providerDetails.experience_yrs || 0 %>" min="0" max="50">
                            </div>
                        <% } %>

                        <button type="submit" class="btn-green w-100 py-2 justify-content-center">
                            Save Changes
                        </button>
                    </form>
                </div>
            </div>

            <!-- Right: Address Settings (Only for customers) -->
            <% if (user.role === 'customer') { %>
            <div class="col-lg-7">
                <!-- Address List -->
                <div class="dark-card mb-4">
                    <h2 style="font-size:1.3rem;font-weight:600;margin-bottom:0.25rem;">My Addresses</h2>
                    <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1.5rem;">Manage your default shipping/booking locations.</p>

                    <% if (addresses.length === 0) { %>
                        <div class="text-center py-4" style="border:1px dashed var(--border-color);border-radius:var(--radius-md);background:var(--bg-secondary);">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" style="width:36px;height:36px;margin-bottom:0.5rem;opacity:0.6;"><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"/><circle cx="12" cy="10" r="3"/></svg>
                            <p style="font-size:0.88rem;color:var(--text-muted);margin:0;">No addresses added yet. Add an address below to enable bookings.</p>
                        </div>
                    <% } else { %>
                        <div class="row g-3">
                            <% addresses.forEach(function(addr) { %>
                                <div class="col-12">
                                    <div class="dark-card-sm d-flex justify-content-between align-items-center flex-wrap gap-3" style="background:var(--bg-secondary);border-color:var(--border-color);">
                                        <div style="flex:1;min-width:200px;">
                                            <div style="font-weight:600;font-size:0.88rem;color:var(--text-primary);display:flex;align-items:center;gap:6px;">
                                                <span style="font-size:0.68rem;font-weight:600;padding:2px 6px;border-radius:4px;background:rgba(var(--color-ink-rgb,0,0,0),0.06);color:var(--color-ink);text-transform:uppercase;"><%= addr.address_type || 'Home' %></span>
                                                <%= addr.line1 %>
                                                <% if (addr.line2) { %>, <%= addr.line2 %><% } %>
                                            </div>
                                            <div style="font-size:0.8rem;color:var(--color-metal);margin-top:2px;">
                                                <%= addr.city %>, <%= addr.state %> — <%= addr.pincode %>
                                            </div>
                                        </div>
                                        
                                        <div class="d-flex align-items-center gap-2">
                                            <% if (addr.is_default) { %>
                                                <span class="badge-status badge-completed">Default</span>
                                            <% } else { %>
                                                <form action="/profile/address/<%= addr.address_id %>/default" method="POST" style="margin:0;">
                                                    <button type="submit" class="btn-outline-custom py-1 px-2" style="font-size:0.75rem;">Make Default</button>
                                                </form>
                                            <% } %>
                                            <form action="/profile/address/<%= addr.address_id %>/delete" method="POST" style="margin:0;" onsubmit="return confirm('Are you sure you want to delete this address?');">
                                                <button type="submit" class="btn-danger-custom py-1 px-2" style="font-size:0.75rem;">Delete</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>

                <!-- Add Address Form -->
                <div class="dark-card">
                    <h2 style="font-size:1.15rem;font-weight:600;margin-bottom:0.25rem;">Add New Address</h2>
                    <p style="color:var(--text-muted);font-size:0.82rem;margin-bottom:1.25rem;">Add another delivery or service location.</p>

                    <form action="/profile/address" method="POST" class="form-dark">
                        <div class="mb-3">
                            <label for="line1" class="form-label">Address Line 1</label>
                            <input type="text" class="form-control" id="line1" name="line1" value="<%= locals.formData.line1 || '' %>" required placeholder="e.g. Flat/House No, Building Name">
                        </div>
                        <div class="mb-3">
                            <label for="line2" class="form-label">Address Line 2 (Optional)</label>
                            <input type="text" class="form-control" id="line2" name="line2" value="<%= locals.formData.line2 || '' %>" placeholder="e.g. Street, Locality">
                        </div>
                        
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label for="city" class="form-label">City</label>
                                <input type="text" class="form-control" id="city" name="city" value="<%= locals.formData.city || '' %>" required placeholder="e.g. Mumbai">
                            </div>
                            <div class="col-md-4">
                                <label for="state" class="form-label">State</label>
                                <input type="text" class="form-control" id="state" name="state" value="<%= locals.formData.state || '' %>" required placeholder="e.g. Maharashtra">
                            </div>
                            <div class="col-md-4">
                                <label for="pincode" class="form-label">Pincode</label>
                                <input type="text" class="form-control" id="pincode" name="pincode" value="<%= locals.formData.pincode || '' %>" required pattern="\d{6}" placeholder="6-digit PIN">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="address_type" class="form-label">Address Type</label>
                            <select class="form-select" id="address_type" name="address_type" required>
                                <option value="Home" <%= locals.formData.address_type === 'Home' ? 'selected' : '' %>>Home</option>
                                <option value="Work" <%= locals.formData.address_type === 'Work' ? 'selected' : '' %>>Work</option>
                                <option value="Other" <%= locals.formData.address_type === 'Other' ? 'selected' : '' %>>Other</option>
                            </select>
                        </div>

                        <div class="mb-4 d-flex align-items-center">
                            <input type="checkbox" id="is_default" name="is_default" style="margin-right:8px;width:16px;height:16px;accent-color:var(--color-ink);">
                            <label for="is_default" style="font-size:0.85rem;color:var(--text-secondary);cursor:pointer;user-select:none;">Set as default address</label>
                        </div>

                        <button type="submit" class="btn-green w-100 py-2 justify-content-center">
                            Add Address
                        </button>
                    </form>
                </div>
            </div>
            <% } %>
        </div>

    </div>
</div>

<%- include('partials/footer') %>
