<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="page-wrapper" style="padding-top: 110px;">
    <div class="container-xl">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="dark-card p-4">
                    <h1 class="text-center mb-2" style="font-size:1.6rem;">Create Account</h1>
                    <p class="text-center" style="color:var(--text-muted);font-size:0.88rem;margin-bottom:1.75rem;">Join HomeServe to book or provide home services.</p>

                    <!-- Render Server-Side Validation Errors -->
                    <% if (locals.errors && errors.length > 0) { %>
                        <div class="alert-dark-error mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            <ul class="mb-0 ps-3" style="list-style-type: none; padding-left: 0 !important;">
                                <% errors.forEach(function(error) { %>
                                    <li><%= error.msg %></li>
                                <% }) %>
                            </ul>
                        </div>
                    <% } %>

                    <form action="/register" method="POST" class="form-dark" id="registerForm">
                        <!-- Role Toggle -->
                        <div class="mb-4">
                            <label class="form-label" style="margin-bottom:8px;">I want to</label>
                            <div style="display:flex;gap:4px;border-radius:var(--radius-buttons);background:var(--bg-secondary);padding:4px;border:1px solid var(--border-color);">
                                <button type="button" class="role-toggle-btn <%= (!locals.role || locals.role === 'customer') ? 'active' : '' %>" data-role="customer" id="roleCustomerBtn"
                                    style="flex:1;padding:8px 16px;border:none;border-radius:6px;background:<%= (!locals.role || locals.role === 'customer') ? 'var(--color-ink)' : 'transparent' %>;color:<%= (!locals.role || locals.role === 'customer') ? 'var(--color-white)' : 'var(--color-metal)' %>;font-size:0.85rem;font-weight:500;cursor:pointer;transition:all 0.2s ease;display:flex;align-items:center;justify-content:center;gap:6px;">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    Book Services
                                </button>
                                <button type="button" class="role-toggle-btn <%= (locals.role === 'provider') ? 'active' : '' %>" data-role="provider" id="roleProviderBtn"
                                    style="flex:1;padding:8px 16px;border:none;border-radius:6px;background:<%= (locals.role === 'provider') ? 'var(--color-ink)' : 'transparent' %>;color:<%= (locals.role === 'provider') ? 'var(--color-white)' : 'var(--color-metal)' %>;font-size:0.85rem;font-weight:500;cursor:pointer;transition:all 0.2s ease;display:flex;align-items:center;justify-content:center;gap:6px;">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                                    Provide Services
                                </button>
                            </div>
                            <input type="hidden" name="role" id="roleInput" value="<%= locals.role || 'customer' %>">
                        </div>

                        <div class="mb-3">
                            <label for="name" class="form-label">Full Name</label>
                            <input type="text" class="form-control" id="name" name="name" value="<%= locals.name || '' %>" required minlength="2" placeholder="e.g. Raj Patel">
                        </div>
                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address</label>
                            <input type="email" class="form-control" id="email" name="email" value="<%= locals.email || '' %>" required placeholder="name@example.com">
                        </div>
                        <div class="mb-3">
                            <label for="phone" class="form-label">Mobile Number</label>
                            <input type="tel" class="form-control" id="phone" name="phone" value="<%= locals.phone || '' %>" placeholder="10-digit mobile number" required pattern="\d{10}">
                        </div>
                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <div class="password-container">
                                <input type="password" class="form-control" id="password" name="password" required minlength="6" placeholder="At least 6 characters">
                                <button type="button" id="togglePassword" class="btn-toggle-password" aria-label="Toggle password visibility">
                                    <svg xmlns="http://www.w3.org/2000/svg" id="eyeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px;">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                        <circle cx="12" cy="12" r="3"></circle>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <!-- Provider-specific fields (hidden by default) -->
                        <div id="providerFields" style="display:<%= (locals.role === 'provider') ? 'block' : 'none' %>;overflow:hidden;transition:all 0.3s ease;">
                            <hr style="opacity:0.12;margin:16px 0;">
                            <p style="font-size:0.82rem;color:var(--text-muted);margin-bottom:12px;">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;opacity:0.6;"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                                Provider Details
                            </p>
                            <div class="mb-3">
                                <label for="bio" class="form-label">Bio / Description</label>
                                <textarea class="form-control" id="bio" name="bio" rows="3" placeholder="Tell customers about your expertise..." style="resize:vertical;"><%= locals.bio || '' %></textarea>
                            </div>
                            <div class="mb-3">
                                <label for="experience_yrs" class="form-label">Years of Experience</label>
                                <input type="number" class="form-control" id="experience_yrs" name="experience_yrs" value="<%= locals.experience_yrs || '' %>" min="0" max="50" placeholder="e.g. 5">
                            </div>
                        </div>
                        
                        <div class="pt-2">
                            <button type="submit" class="btn-green w-100 py-2">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;margin-right:4px;"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                                Sign Up
                            </button>
                        </div>
                    </form>

                    <p class="text-center mt-4 mb-0" style="font-size:0.88rem;color:var(--text-muted);">
                        Already have an account? <a href="/login" class="text-green" style="font-weight: 500;">Login here</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const customerBtn = document.getElementById('roleCustomerBtn');
    const providerBtn = document.getElementById('roleProviderBtn');
    const roleInput = document.getElementById('roleInput');
    const providerFields = document.getElementById('providerFields');

    function setRole(role) {
        roleInput.value = role;
        if (role === 'provider') {
            providerBtn.style.background = 'var(--color-ink)';
            providerBtn.style.color = 'var(--color-white)';
            customerBtn.style.background = 'transparent';
            customerBtn.style.color = 'var(--color-metal)';
            providerFields.style.display = 'block';
        } else {
            customerBtn.style.background = 'var(--color-ink)';
            customerBtn.style.color = 'var(--color-white)';
            providerBtn.style.background = 'transparent';
            providerBtn.style.color = 'var(--color-metal)';
            providerFields.style.display = 'none';
        }
    }

    customerBtn.addEventListener('click', function() { setRole('customer'); });
    providerBtn.addEventListener('click', function() { setRole('provider'); });

    // Password visibility toggle logic
    const togglePassword = document.querySelector('#togglePassword');
    const passwordInput = document.querySelector('#password');
    const eyeIcon = document.querySelector('#eyeIcon');

    if (togglePassword && passwordInput && eyeIcon) {
        togglePassword.addEventListener('click', function () {
            const isPassword = passwordInput.getAttribute('type') === 'password';
            passwordInput.setAttribute('type', isPassword ? 'text' : 'password');
            
            if (isPassword) {
                eyeIcon.innerHTML = `
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                    <line x1="1" y1="1" x2="23" y2="23"></line>
                `;
            } else {
                eyeIcon.innerHTML = `
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                `;
            }
        });
    }
});
</script>

<%- include('partials/footer') %>

