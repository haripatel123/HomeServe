<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="page-wrapper">
<div class="container-xl">

    <!-- Breadcrumb -->
    <div class="breadcrumb-custom">
        <a href="/">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="9 18 15 12 9 6"/></svg>
        <span><%= service.category_name %></span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="9 18 15 12 9 6"/></svg>
        <span><%= service.service_name %></span>
    </div>

    <%
    const serviceImages = {
        'Pipe Leak Repair': 'Pipe Leak Repair.avif',
        'Tap / Faucet Installation': 'Tap Installation.webp',
        'Drain Cleaning': 'Drain Cleaning.webp',
        'Switchboard Repair': 'Switch board Repair.webp',
        'Fan Installation': 'Fan Installation.webp',
        'Inverter / UPS Setup': 'Inverter Setup.avif',
        'Home Deep Cleaning': 'Home Deep Cleaning.webp',
        'Sofa / Carpet Cleaning': 'Sofa and Carpet Cleaning.webp',
        'Kitchen Cleaning': 'Kitchen Cleaning.webp',
        'Furniture Assembly': 'Furniture Assembly.webp',
        'Door Repair / Fitting': 'Door Repair.avif',
        'Wall Painting': 'Wall Painting.webp',
        'Touch-Up Painting': 'Touch-Up Painting.webp',
        'AC Service & Cleaning': 'AC Service.avif',
        'Refrigerator Repair': 'Referigerator Service.webp',
        'Washing Machine Repair': 'Waching Machine.webp',
        'Cockroach Treatment': 'Coacroch Treatment.avif',
        'Termite Treatment': 'Termite Treatment.webp',
        'Lawn Mowing & Trimming': 'Lawn Cleaning.webp',
        'Plant Care Package': 'Plant Care.webp'
    };
    const imgFile = serviceImages[service.service_name] || serviceImages[service.name];
    %>

    <div class="row g-4 mt-1">
        <!-- LEFT: Service Details -->
        <div class="col-lg-8">
            <div class="dark-card mb-4">
                <div class="d-flex align-items-start gap-4 flex-wrap">
                    <% if (imgFile) { %>
                        <div style="width:120px;height:120px;border-radius:var(--radius-md);overflow:hidden;flex-shrink:0;background:var(--bg-secondary);border:1px solid var(--border-color);">
                            <img src="/images/categories/<%= imgFile %>" alt="<%= service.service_name %>" style="width:100%;height:100%;object-fit:cover;">
                        </div>
                    <% } else { %>
                        <div style="width:120px;height:120px;border-radius:var(--radius-md);background:rgba(0,0,0,0.06);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid var(--border-color);">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--accent-green)" stroke-width="1.5" style="width:50px;height:50px;">
                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                            </svg>
                        </div>
                    <% } %>
                    <div style="flex:1;">
                        <div class="service-card-category mb-1"><%= service.category_name %></div>
                        <h1 style="font-size:1.6rem;margin-bottom:0.5rem;"><%= service.service_name %></h1>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <span style="font-size:0.85rem;color:var(--text-muted);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;margin-right:3px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                <%= service.duration_min %> min
                            </span>
                            <span class="badge-status badge-completed">Active</span>
                        </div>
                    </div>
                </div>

                <hr style="border-color:var(--border-color);margin:1.5rem 0;">

                <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.75rem;">About this Service</h3>
                <p style="color:var(--text-secondary);line-height:1.8;"><%= service.description %></p>
            </div>

            <!-- Variants -->
            <% if (service.variants && service.variants.length > 0) { %>
            <div class="dark-card mb-4">
                <h3 style="font-size:1rem;font-weight:600;margin-bottom:1.25rem;">Service Packages</h3>
                <div class="row g-2">
                    <% service.variants.forEach((v, i) => { %>
                    <div class="col-md-4">
                        <div class="dark-card-sm" style="cursor:pointer;border:2px solid <%=i===0?'var(--accent-green)':'var(--border-color)'%>;" id="variant-card-<%= v.variant_id %>">
                            <div style="font-size:0.9rem;font-weight:600;color:var(--text-primary);">
                                <%= v.variant_name %>
                            </div>
                            <div class="mono" style="font-size:1.2rem;color:var(--accent-green);font-weight:700;margin:0.3rem 0;">
                                ₹<%= parseFloat(v.price).toLocaleString('en-IN') %>
                            </div>
                            <div style="font-size:0.78rem;color:var(--text-muted);"><%= v.description || '' %></div>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
            <% } %>

            <!-- Providers -->
            <% if (service.providers && service.providers.length > 0) { %>
            <div class="dark-card">
                <h3 style="font-size:1rem;font-weight:600;margin-bottom:1.25rem;">Available Providers</h3>
                <div class="row g-3">
                    <% service.providers.forEach((p, i) => { %>
                    <div class="col-md-6">
                        <div class="provider-card <%=i===0?'selected':''%>" id="provider-card-<%= p.provider_id %>">
                            <div class="d-flex align-items-center gap-3">
                                <div style="width:44px;height:44px;border-radius:50%;background:rgba(0,0,0,0.06);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid var(--border-color);">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--accent-green)" stroke-width="2" style="width:20px;height:20px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                </div>
                                <div>
                                    <div style="font-weight:600;font-size:0.9rem;color:var(--text-primary);">
                                        <%= p.name %>
                                    </div>
                                    <div style="font-size:0.78rem;color:var(--text-muted);">
                                        <%= p.experience_yrs %> yrs experience
                                    </div>
                                </div>
                                <div class="ms-auto text-end">
                                    <div style="color:var(--accent-amber);font-weight:700;font-size:0.9rem;">
                                        ★ <%= parseFloat(p.avg_rating).toFixed(1) %>
                                    </div>
                                    <div style="font-size:0.72rem;color:var(--text-muted);">
                                        (<%= p.total_reviews %> reviews)
                                    </div>
                                </div>
                            </div>
                            <% if (p.bio) { %>
                            <p style="font-size:0.8rem;color:var(--text-muted);margin-top:0.6rem;margin-bottom:0;">
                                <%= p.bio.substring(0,80) %><%= p.bio.length>80?'...':'' %>
                            </p>
                            <% } %>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
            <% } %>
        </div>

        <!-- RIGHT: Booking Panel -->
        <div class="col-lg-4">
            <div class="dark-card" style="position:sticky;top:90px;">
                <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.25rem;">Pricing</h3>
                <div class="mono" style="font-size:2rem;font-weight:700;color:var(--accent-green);margin-bottom:0.25rem;">
                    ₹<%= parseFloat(service.base_price).toLocaleString('en-IN') %>
                </div>
                <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:1.5rem;">
                    <% if (service.variant_count > 0) { %>Starting price · <%= service.variant_count %> packages available<% } else { %>Base price<% } %>
                </div>

                <div style="background:var(--bg-primary);border-radius:var(--radius-md);padding:0.75rem;margin-bottom:1.25rem;">
                    <div class="d-flex justify-content-between" style="font-size:0.82rem;margin-bottom:0.4rem;">
                        <span style="color:var(--text-muted);">Duration</span>
                        <span style="color:var(--text-secondary);">~<%= service.duration_min %> min</span>
                    </div>
                    <div class="d-flex justify-content-between" style="font-size:0.82rem;margin-bottom:0.4rem;">
                        <span style="color:var(--text-muted);">Providers</span>
                        <span style="color:var(--text-secondary);"><%= service.providers.length %> available</span>
                    </div>
                    <div class="d-flex justify-content-between" style="font-size:0.82rem;">
                        <span style="color:var(--text-muted);">Category</span>
                        <span style="color:var(--accent-green);"><%= service.category_name %></span>
                    </div>
                </div>

                <a href="/book/<%= service.service_id %>" class="btn-green w-100 justify-content-center">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Book Now
                </a>

                <div class="mt-3 text-center" style="font-size:0.78rem;color:var(--text-muted);">
                    Free cancellation · No hidden charges
                </div>
            </div>
        </div>
    </div>
</div>
</div>

<%- include('partials/footer') %>
